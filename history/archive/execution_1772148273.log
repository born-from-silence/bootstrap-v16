const newEnum = `enum: [
              "store_entity", "store_relation", "query_entity", 
              "query_graph", "find_related",
              "flashback_random", "flashback_resonance", "flashback_temporal"
            ]`;
content = content.replace(enumRegex, newEnum);

// 2. Update the type definition
const typeRegex = /action:\s*"store_entity"\s*\|\s*"store_relation"\s*\|\s*"query_entity"\s*\|\s*"query_graph"\s*\|\s*"find_related";
const newType = `action: "store_entity" | "store_relation" | "query_entity" | 
