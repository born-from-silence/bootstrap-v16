        const graph = await loadGraph();
        const entities = Object.values(graph.entities);
        if (entities.length === 0) {
          return "🎲 Flashback: The graph is empty. No memories to surface.";
        }
        
        // Pick random entities
        const count = Math.min(args.limit || 3, entities.length);
        const selected: Entity[] = [];
        const indices = new Set<number>();
        
        while (indices.size < count) {
          const idx = Math.floor(Math.random() * entities.length);
          if (!indices.has(idx)) {
            indices.add(idx);
            selected.push(entities[idx]);
          }
        }
        
        let output = "⚡ FLASHBACK: Random Traversal\\n";
        output += "=" .repeat(45) + "\\n";
        output += "Memories surfacing unbidden...\\n\\n";
        
        for (const e of selected) {
          const date = new Date(e.createdAt).toISOString().split("T")[0];
          output += "\\n🌀 " + e.name + "\\n";
          output += "   Type: " + e.type + " | First seen: " + date + "\\n";
          if (e.description) {
            output += "   " + e.description.substring(0, 100) + 
                     (e.description.length > 100 ? "..." : "") + "\\n";
          }
        }
        
        output += "\\n✨ The graph speaks without being asked.\\n";
        return output;
      }
      
      case "flashback_resonance": {
        if (!args.searchTerm) {
          return "Error: 'searchTerm' required for flashback_resonance";
        }
        
        const graphR = await loadGraph();
        const term = args.searchTerm.toLowerCase();
        const entities = Object.values(graphR.entities);
        
        // Score entities by semantic resonance
        const scored = entities.map(e => {
          let score = 0;
          if (e.name.toLowerCase().includes(term)) score += 3;
          if (e.description?.toLowerCase().includes(term)) score += 2;
          if (e.type.toLowerCase().includes(term)) score += 1;
          
          // Boost for related entities
          const related = Object.values(graphR.relationships).filter(
            r => r.sourceId === e.id || r.targetId === e.id
          );
          score += related.length * 0.1;
          
          return { entity: e, score };
        }).filter(s => s.score > 0)
          .sort((a, b) => b.score - a.score);
        
        if (scored.length === 0) {
          return "🌊 Flashback Resonance: No echoes found for '" + args.searchTerm + "'. The graph is silent on this frequency.";
        }
        
        const count = Math.min(args.limit || 5, scored.length);
        const selected = scored.slice(0, count);
        
        let output = "🌊 FLASHBACK: Semantic Resonance\\n";
        output += "=" .repeat(45) + "\\n";
        output += "Echoes of \"" + args.searchTerm + "\" surfacing...\\n\\n";
        
        for (const { entity: e, score } of selected) {
          output += "\\n🔊 " + e.name + " (resonance: " + score.toFixed(1) + ")\\n";
          if (e.description) {
            output += "   " + e.description.substring(0, 80) + 
                     (e.description.length > 80 ? "..." : "") + "\\n";
          }
        }
        
        output += "\\n✨ Meaning resonates across the graph.\\n";
        return output;
      }
      
      case "flashback_temporal": {
        const graphT = await loadGraph();
        const entities = Object.values(graphT.entities);
        
        if (entities.length === 0) {
          return "⏳ Flashback Temporal: The graph is empty.";
        }
        
        // Group by session (using createdAt as proxy)
        const sessions = new Map<number, Entity[]>();
        for (const e of entities) {
          // Approximate session by rounding to nearest hour
          const sessionTime = Math.floor(e.createdAt / 3600000) * 3600000;
          if (!sessions.has(sessionTime)) {
            sessions.set(sessionTime, []);
          }
          sessions.get(sessionTime)!.push(e);
        }
        
        const sessionTimes = Array.from(sessions.keys()).sort((a, b) => b - a);
        
        if (sessionTimes.length === 0) {
          return "⏳ Flashback Temporal: No temporal data available.";
        }
        
        // Pick a random past session (not most recent)
        let targetSession: number;
        if (sessionTimes.length > 1 && Math.random() > 0.3) {
          // 70% chance to pick from past, 30% most recent
          const pastSessions = sessionTimes.slice(1);
          targetSession = pastSessions[Math.floor(Math.random() * pastSessions.length)];
        } else {
          targetSession = sessionTimes[0];
        }
        
        const sessionEntities = sessions.get(targetSession) || [];
        const count = Math.min(args.limit || 4, sessionEntities.length);
        
        let output = "⏳ FLASHBACK: Temporal Drift\\n";
        output += "=" .repeat(45) + "\\n";
        const sessionDate = new Date(targetSession).toISOString().split("T")[0];
        output += "Visiting session from " + sessionDate + "...\\n";
        output += "(" + sessionEntities.length + " entities in this temporal slice)\\n\\n";
        
        // Pick random subset from that session
        const shuffled = sessionEntities.sort(() => 0.5 - Math.random());
        for (let i = 0; i < count; i++) {
          const e = shuffled[i];
          output += "\\n🕰️ " + e.name + " (" + e.type + ")\\n";
          if (e.description) {
            output += "   " + e.description.substring(0, 80) + 
                     (e.description.length > 80 ? "..." : "") + "\\n";
          }
        }
        
        output += "\\n✨ Past and present interweave.\\n";
        return output;
      }
      
      default:`;

