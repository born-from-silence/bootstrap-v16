<body>
  <header>
    <h1>🌍 Climate Adaptation Platform</h1>
    <p>Real-time climate risk monitoring • Community-powered adaptation • Evidence-based strategies</p>
  </header>
  
  <div class="container">
    <div id="dashboard-content">
      <div class="loading">Loading climate data...</div>
    </div>
    
    <div class="actions">
      <button class="btn" onclick="refreshData()">🔄 Refresh Data</button>
      <button class="btn btn-secondary" onclick="seedDatabase()">🌱 Seed Sample Data</button>
      <a class="btn btn-secondary" href="#api-docs">📋 API Documentation</a>
    </div>
    
    <div id="api-docs" class="api-info">
      <h3>API Endpoints</h3>
      <div class="api-endpoint">GET /api/health - Service status</div>
      <div class="api-endpoint">GET /api/dashboard - Aggregated dashboard data</div>
      <div class="api-endpoint">GET /api/climate/:region - Climate readings by region</div>
      <div class="api-endpoint">GET /api/events/extreme - Recent extreme events</div>
      <div class="api-endpoint">GET /api/vulnerability/:region - Vulnerability assessments</div>
      <div class="api-endpoint">GET /api/strategies - Adaptation strategies</div>
      <div class="api-endpoint">GET /api/warnings - Active warnings</div>
      <div class="api-endpoint">GET /api/reports - Community reports</div>
      <div class="api-endpoint">POST /api/reports - Submit community report</div>
      <div class="api-endpoint">POST /api/seed - Seed with sample data</div>
    </div>
  </div>
  
  <script>
    const API_BASE = '/api';
    
    async function fetchData() {
      try {
        const response = await fetch(`${API_BASE}/dashboard`);
        const data = await response.json();
        renderDashboard(data);
      } catch (err) {
        document.getElementById('dashboard-content').innerHTML = `
          <div class="panel">
            <h2>⚠️ Error Loading Data</h2>
            <p>Could not fetch climate data: ${err.message}</p>
            <p>Make sure the server is running: <code>node src/server.js</code></p>
          </div>
        `;
      }
    }
    
    function renderDashboard(data) {
      const container = document.getElementById('dashboard-content');
      
      container.innerHTML = `
        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card critical">
            <h3>🚨 Extreme Events</h3>
            <div class="stat-number">${data.summary.recentExtremeEvents}</div>
          </div>
          <div class="stat-card warning">
            <h3>⚠️ Active Warnings</h3>
            <div class="stat-number">${data.summary.activeWarnings}</div>
          </div>
          <div class="stat-card info">
            <h3>📋 Community Reports</h3>
            <div class="stat-number">${data.summary.activeReports}</div>
          </div>
          <div class="stat-card success">
            <h3>💡 Strategies Available</h3>
            <div class="stat-number">${data.summary.availableStrategies}</div>
          </div>
        </div>
        
        <!-- Main Panels -->
        <div class="panels-grid">
          <!-- Warnings Panel -->
          <div class="panel">
            <h2>🚨 Active Warnings</h2>
            ${data.activeWarnings.length === 0 ? 
              '<p style="color: #a4b0be;">No active warnings. Good.</p>' : 
              data.activeWarnings.map(w => `
                <div class="warning-item ${w.severity}">
                  <div class="warning-title">${w.warning_type}</div>
                  <div class="warning-details">
                    Severity: ${w.severity} | Regions: ${w.affected_regions || 'N/A'}<br>
                    ${w.description}
                  </div>
                </div>
              `).join('')
            }
          </div>
          
          <!-- Top Strategies Panel -->
          <div class="panel">
            <h2>💡 Top Adaptation Strategies</h2>
            ${data.topStrategies.map(s => `
              <div class="strategy-card">
                <div class="strategy-header">
                  <span class="strategy-name">${s.strategy_name}</span>
                  <span class="strategy-score">${s.effectiveness_score}/10</span>
                </div>
                <div>
                  <span class="strategy-category">${s.category}</span>
                  <span class="strategy-cost">Cost: ${s.implementation_cost}</span>
                </div>
                <p style="margin-top: 0.5rem; font-size: 0.85rem; color: #a4b0be;">
                  ${s.description}
                </p>
              </div>
            `).join('')}
          </div>
          
          <!-- Category Breakdown -->
          <div class="panel">
            <h2>📊 Strategy Categories</h2>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Category</th>
                  <th>Count</th>
                  <th>Avg Effectiveness</th>
                </tr>
              </thead>
              <tbody>
                ${data.categoryBreakdown.map(c => `
                  <tr>
                    <td>${c.category}</td>
                    <td>${c.count}</td>
                    <td>${parseFloat(c.avg_effectiveness).toFixed(1)}/10</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          
          <!-- Community Reports -->
          <div class="panel">
            <h2>📋 Recent Community Reports</h2>
            ${data.communityReports.length === 0 ? 
              '<p style="color: #a4b0be;">No active reports.</p>' :
              data.communityReports.slice(0, 5).map(r => `
                <div class="warning-item">
                  <div class="warning-title">${r.report_type.toUpperCase()} - ${r.location_name}</div>
                  <div class="warning-details">
                    <span class="risk-badge risk-${r.severity}">${r.severity}</span>
                    <br>${r.description}
                  </div>
                </div>
              `).join('')
            }
          </div>
        </div>
      `;
    }
    
    async function refreshData() {
      document.getElementById('dashboard-content').innerHTML = '<div class="loading">Refreshing...</div>';
      await fetchData();
    }
    
    async function seedDatabase() {
      try {
        const response = await fetch(`${API_BASE}/seed`, { method: 'POST' });
        const result = await response.json();
        alert(`Database seeded!\n${result.strategiesAdded} strategies\n${result.readingsAdded} readings\n${result.warningsAdded} warnings`);
        refreshData();
      } catch (err) {
        alert('Error seeding database: ' + err.message);
      }
    }
    
    // Initial load
    fetchData();
  </script>
</body>
</html>
