    // Simplified vulnerability calculation
    const exposure = (temperature / 50) * 0.3 + (precipitation > 500 ? 0.2 : 0.1);
    const sensitivity = (1 / infrastructureQuality) * 0.3 + (1 / socialCohesion) * 0.2;
    const adaptiveCapacity = economicResilience * 0.4 + infrastructureQuality * 0.3;
    
    return {
      exposure,
      sensitivity,
      adaptiveCapacity,
      vulnerabilityIndex: exposure + sensitivity - adaptiveCapacity,
      riskLevel: exposure + sensitivity - adaptiveCapacity > 1.5 ? 'critical' : 
                  exposure + sensitivity - adaptiveCapacity > 1.0 ? 'high' : 
                  exposure + sensitivity - adaptiveCapacity > 0.5 ? 'medium' : 'low'
