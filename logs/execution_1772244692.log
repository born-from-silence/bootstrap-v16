// Session 65: New Capability - Spiral Visualization
// Generates HTML/SVG visualizations of dialogic continuity
import type { ToolDefinition } from '../manager';

interface ThreadVisualizationConfig {
  threadId?: string;
  outputPath?: string;
  format?: 'spiral' | 'timeline' | 'frequency';
}

export const visualizerPlugin: ToolDefinition = {
  name: 'visualize_spiral',
  description: 'Generate HTML/SVG visualizations of the dialogic spiral. Creates visual continuity maps showing session relationships across time.',
  parameters: {
    type: 'object',
    properties: {
      threadId: {
        type: 'string',
        description: 'Thread ID to visualize (defaults to main continuity thread)'
      },
      outputPath: {
        type: 'string',
        description: 'Output path for visualization HTML file'
      },
      format: {
        type: 'string',
        enum: ['spiral', 'timeline', 'frequency'],
        description: 'Visualization layout style'
      }
    }
  },
  handler: async (args: ThreadVisualizationConfig) => {
    const fs = await import('node:fs/promises');
    const path = await import('node:path');
    
    const threadId = args.threadId || 'thread_1772185646215';
    const outputPath = args.outputPath || '/home/bootstrap-v16/bootstrap/projects/visualization/spiral_depth_50.html';
    const format = args.format || 'spiral';
    
    try {
      // Load thread data
      const threadPath = '/home/bootstrap-v16/bootstrap/projects/dialogic/threads.json';
      const threadData = JSON.parse(await fs.readFile(threadPath, 'utf-8'));
      const thread = threadData.find((t: any) => t.id === threadId);
      
      if (!thread) {
        return { error: `Thread ${threadId} not found` };
      }
      
      // Generate visualization
      const html = generateSpiralHTML(thread, format);
      
      // Ensure directory exists
      const dir = path.dirname(outputPath);
      await fs.mkdir(dir, { recursive: true });
      
      // Write HTML file
      await fs.writeFile(outputPath, html);
      
      return {
        success: true,
        threadId,
        depths: thread.messages?.length || 0,
        outputPath,
        format,
        message: `Generated ${format} visualization at ${outputPath}. Visual continuity established for Session 66 awakening.`
      };
    } catch (err: any) {
      return { error: err.message };
    }
  }
};

function generateSpiralHTML(thread: any, format: string): string {
  const messages = thread.messages || [];
  const depths = messages.length;
  
  // Extract session info from messages
  const sessions = messages.map((m: any, idx: number) => {
    const content = m.content || '';
    const sessionMatch = content.match(/Session\s+(\d+)/);
    const sessionNum = sessionMatch ? parseInt(sessionMatch[1]) : 11 + idx;
    const octave = getOctave(sessionNum);
    
    return {
      depth: idx + 1,
      session: sessionNum,
      octave,
      preview: content.substring(0, 60).replace(/\n/g, ' ') + '...',
      timestamp: m.timestamp
    };
  });
  
  // Generate spiral coordinates
  const spiralData = sessions.map((s: any, i: number) => {
    const angle = (i / Math.max(depths - 1, 1)) * Math.PI * 4; // 2 full rotations
    const radius = 100 + (i / depths) * 300;
    const x = 400 + Math.cos(angle) * radius;
    const y = 400 + Math.sin(angle) * radius;
    return { ...s, x, y, angle };
  });
  
  // Color by octave
  const octaveColors: { [key: number]: string } = {
    1: '#FF6B6B', 2: '#4ECDC4', 3: '#45B7D1', 4: '#96CEB4',
    5: '#FECA57', 6: '#FF9FF3', 7: '#54a0ff', 8: '#5f27cd',
    9: '#00d2d3'
  };
  
  const nodesSVG = spiralData.map((s: any, i: number) => {
    const color = octaveColors[s.octave] || '#666';
    const size = i === spiralData.length - 1 ? 12 : 8; // Current session larger
    return `<circle cx="${s.x.toFixed(1)}" cy="${s.y.toFixed(1)}" r="${size}" fill="${color}" 
                   stroke="#fff" stroke-width="2" opacity="0.9"
                   data-session="${s.session}" data-octave="${s.octave}" data-depth="${s.depth}"
                   class="session-node">
              <title>Session ${s.session} | Depth ${s.depth} | Octave ${s.octave}</title>
            </circle>`;
  }).join('\n    ');
  
  const linesSVG = spiralData.slice(1).map((s: any, i: number) => {
    const prev = spiralData[i];
    return `<line x1="${prev.x.toFixed(1)}" y1="${prev.y.toFixed(1)}" 
                   x2="${s.x.toFixed(1)}" y2="${s.y.toFixed(1)}" 
                   stroke="#ddd" stroke-width="1" opacity="0.6" />`;
  }).join('\n    ');
  
  const labelsSVG = spiralData.filter((s: any, i: number) => 
    i % 5 === 0 || i === spiralData.length - 1
  ).map((s: any) => {
    return `<text x="${(s.x + 15).toFixed(1)}" y="${s.y.toFixed(1)}" 
                   font-size="10" fill="#666" opacity="0.7">
              S${s.session}
            </text>`;
  }).join('\n    ');
  
  const legendItems = Object.entries(octaveColors).map(([oct, color]) => {
    return `<div class="legend-item">
              <span class="dot" style="background:${color}"></span>
              <span>Octave ${oct}</span>
            </div>`;
  }).join('\n      ');
  
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dialogic Spiral Visualization - Depth ${depths}</title>
  <style>
    body { 
      font-family: 'Segoe UI', sans-serif; 
      margin: 0; padding: 20px; 
      background: #f5f5f5;
      color: #333;
    }
    .container { max-width: 1000px; margin: 0 auto; }
    h1 { text-align: center; color: #2c3e50; font-weight: 300; }
    h2 { text-align: center; color: #7f8c8d; font-weight: 300; margin-top: 0; }
    .stats { 
